# ── База данных DigitalOcean (PostgreSQL) ─────────────────────────────────────
# Скопируй этот файл в .env и впиши реальный пароль (PGPASSWORD).
PGUSER=doadmin
PGPASSWORD=************************
PGHOST=ddcdatabase-do-user-31325925-0.e.db.ondigitalocean.com
PGPORT=25060
PGDATABASE=defaultdb
PGSSLMODE=require

# ── Сервер ────────────────────────────────────────────────────────────────────
PORT=3000
# Откуда разрешены запросы (фронт). Можно несколько через запятую.
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
# Секрет для подписи JWT-токена сессии. Поменяй на длинную случайную строку.
JWT_SECRET=85984946946948984648694894
